}
:add_add SIMM4_B3_HI, RREG_B3_LO, RREG_B2_HI, RREG_B2_LO is b0_any=0xF7; b1_any=0x04; RREG_B2_HI & RREG_B2_LO; SIMM4_B3_HI & RREG_B3_LO {
    local s1:4 = sext(SIMM4_B3_HI);
    update_add32(RREG_B3_LO, s1);
    update_add32(RREG_B2_LO, RREG_B2_HI);
}
:add_add SIMM4_B3_HI, RREG_B3_LO, SIMM4_B2_HI, RREG_B2_LO is b0_any=0xF7; b1_any=0x14; SIMM4_B2_HI & RREG_B2_LO; SIMM4_B3_HI & RREG_B3_LO {
    local s1:4 = sext(SIMM4_B3_HI);
    local s2:4 = sext(SIMM4_B2_HI);
    update_add32(RREG_B3_LO, s1);
    update_add32(RREG_B2_LO, s2);
}

:sub DREG_D0_HI, DREG_D0_LO is b0_any=0xF1; b1_7=0 & b1_6=0 & b1_5=0 & b1_4=0 & DREG_D0_HI & DREG_D0_LO { update_sub32(DREG_D0_LO, DREG_D0_HI); }
:sub DREG_D0_HI, AREG_D0_LO is b0_any=0xF1; b1_7=0 & b1_6=0 & b1_5=1 & b1_4=0 & DREG_D0_HI & AREG_D0_LO { update_sub32(AREG_D0_LO, DREG_D0_HI); }
:sub AREG_D0_HI, DREG_D0_LO is b0_any=0xF1; b1_7=0 & b1_6=0 & b1_5=0 & b1_4=1 & AREG_D0_HI & DREG_D0_LO { update_sub32(DREG_D0_LO, AREG_D0_HI); }
:sub AREG_D0_HI, AREG_D0_LO is b0_any=0xF1; b1_7=0 & b1_6=0 & b1_5=1 & b1_4=1 & AREG_D0_HI & AREG_D0_LO { update_sub32(AREG_D0_LO, AREG_D0_HI); }
:sub RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0x98; RREG_B2_HI & RREG_B2_LO { update_sub32(RREG_B2_LO, RREG_B2_HI); }
:sub IMM32_B2345, DREG_D0_LO is b0_any=0xFC; b1_7=1 & b1_6=1 & b1_5=0 & b1_4=0 & b1_3=0 & b1_2=1 & DREG_D0_LO; IMM32_B2345 { update_sub32(DREG_D0_LO, IMM32_B2345); }
:sub IMM32_B2345, AREG_D0_LO is b0_any=0xFC; b1_7=1 & b1_6=1 & b1_5=0 & b1_4=1 & b1_3=0 & b1_2=1 & AREG_D0_LO; IMM32_B2345 { update_sub32(AREG_D0_LO, IMM32_B2345); }

:sub_sub RREG_B3_HI, RREG_B3_LO, RREG_B2_HI, RREG_B2_LO is b0_any=0xF7; b1_any=0x22; RREG_B2_HI & RREG_B2_LO; RREG_B3_HI & RREG_B3_LO {
