:sub_sub RREG_B3_HI, RREG_B3_LO, SIMM4_B2_HI, RREG_B2_LO is b0_any=0xF7; b1_any=0x32; SIMM4_B2_HI & RREG_B2_LO; RREG_B3_HI & RREG_B3_LO {
