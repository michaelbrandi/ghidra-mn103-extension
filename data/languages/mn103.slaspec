:addc SIMM8_B3, RREG_RN02_EQ is b0_any=0xFB; b1_any=0x88; b2_rhi=b2_rlo & RREG_RN02_EQ; SIMM8_B3 { local s:4 = sext(SIMM8_B3); update_addc32(RREG_RN02_EQ, s); }
