    export *[ram]:4 a;
}

IND_AREG_D0: "("^AREG_D0_LO^")" is AREG_D0_LO { export AREG_D0_LO; }
PCREL8_S1: addr is b1_simm [ addr = inst_start + b1_simm; ] { export *:4 addr; }
PCREL8_D1: addr is b2_simm [ addr = inst_start + b2_simm; ] { export *:4 addr; }
PCREL16_S2: addr is u16_simm [ addr = inst_start + u16_simm; ] { export *:4 addr; }
PCREL16_D2: addr is u16_simm [ addr = inst_start + u16_simm; ] { export *:4 addr; }
PCREL32_D4: addr is u32_simm [ addr = inst_start + u32_simm; ] { export *:4 addr; }
LOOP4BACK: addr is epsilon [ addr = inst_start - 4; ] { export *:4 addr; }

# Register-list rendering used by call/ret family:
# bit7..bit0 = d2,d3,a2,a3,other,exreg0,exreg1,exother.
REGLIST_B1: "[]" is b1_any=0x00 { }
REGLIST_B1: "[d2]" is b1_any=0x80 { }
REGLIST_B1: "[d3]" is b1_any=0x40 { }
REGLIST_B1: "[a2]" is b1_any=0x20 { }
REGLIST_B1: "[a3]" is b1_any=0x10 { }
REGLIST_B1: "[d2,d3]" is b1_any=0xC0 { }
REGLIST_B1: "[d3,a2]" is b1_any=0x60 { }
REGLIST_B1: "[d2,d3,a2]" is b1_any=0xE0 { }
REGLIST_B1: "[d2,d3,a2,a3]" is b1_any=0xF0 { }
REGLIST_B1: "[d2,d3,a2,a3,exreg1]" is b1_any=0xF2 { }
REGLIST_B1: "["^b1_imm^"]" is b1_imm { }

REGLIST_B2: "[]" is b2_any=0x00 { }
REGLIST_B2: "[d2]" is b2_any=0x80 { }
REGLIST_B2: "[d3]" is b2_any=0x40 { }
REGLIST_B2: "[a2]" is b2_any=0x20 { }
REGLIST_B2: "[a3]" is b2_any=0x10 { }
