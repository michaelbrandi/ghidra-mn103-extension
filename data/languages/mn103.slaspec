MEM_SD24_RREG_HI_D8: "(0x"^b5_any^b4_any^b3_any^","^RREG_B2_HI^")" is RREG_B2_HI; b3_any; b4_any; b5_any {
    local b3v:3 = b3_any;
    local b4v:3 = b4_any;
    local b5v:3 = b5_any;
    local off24:3 = b3v | (b4v << 8) | (b5v << 16);
    local a:4 = RREG_B2_HI + sext(off24);
    export *[ram]:4 a;
