:subc DREG_D0_HI, DREG_D0_LO is b0_any=0xF1; b1_7=1 & b1_6=0 & b1_5=0 & b1_4=0 & DREG_D0_HI & DREG_D0_LO { update_subc32(DREG_D0_LO, DREG_D0_HI); }
:subc RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0xA8; RREG_B2_HI & RREG_B2_LO { update_subc32(RREG_B2_LO, RREG_B2_HI); }
:subc SIMM8_B3, RREG_RN02_EQ is b0_any=0xFB; b1_any=0xA8; b2_rhi=b2_rlo & RREG_RN02_EQ; SIMM8_B3 { local s:4 = sext(SIMM8_B3); update_subc32(RREG_RN02_EQ, s); }
:subc SIMM24_B345, RREG_RN02_EQ is b0_any=0xFD; b1_any=0xA8; b2_rhi=b2_rlo & RREG_RN02_EQ; SIMM24_B345 { local s:4 = sext(SIMM24_B345); update_subc32(RREG_RN02_EQ, s); }
:subc IMM32HI8_B3456, RREG_RN02_EQ is b0_any=0xFE; b1_any=0xA8; b2_rhi=b2_rlo & RREG_RN02_EQ; IMM32HI8_B3456 { update_subc32(RREG_RN02_EQ, IMM32HI8_B3456); }

:mulu DREG_D0_HI, DREG_D0_LO is b0_any=0xF2; b1_7=0 & b1_6=1 & b1_5=0 & b1_4=1 & DREG_D0_HI & DREG_D0_LO { update_mulu32(DREG_D0_LO, DREG_D0_HI); }
:mulu RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0xB9; RREG_B2_HI & RREG_B2_LO { update_mulu32(RREG_B2_LO, RREG_B2_HI); }
:mulu IMM8_B3, RREG_RN02_EQ is b0_any=0xFB; b1_any=0xB9; b2_rhi=b2_rlo & RREG_RN02_EQ; IMM8_B3 {
