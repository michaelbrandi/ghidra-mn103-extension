define token b6 (8)
    b6_any = (0,7)
    b6_imm = (0,7) hex
    b6_simm = (0,7) signed hex
    b6_areg0 = (0,1)
    b6_dlo = (0,1)
    b6_dhi = (2,3)
    b6_d2 = (4,5)
    b6_alo = (0,1)
    b6_ahi = (2,3)
    b6_a2 = (4,5)
