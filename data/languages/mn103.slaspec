    MCRH = *[ram]:4 p; p = p + 4;
    MDRQ = *[ram]:4 p; p = p + 4;
    R1 = *[ram]:4 p; p = p + 4;
    R0 = *[ram]:4 p; p = p + 4;
<USP_POP_NO_EXOTHER>

    if ((mask & 0x02) == 0) goto <USP_POP_NO_EXREG1>;
