:jmp IND_AREG_D0 is b0_any=0xF0; b1_7=1 & b1_6=1 & b1_5=1 & b1_4=1 & b1_3=0 & b1_2=1 & IND_AREG_D0 { goto [IND_AREG_D0]; }
:jmp PCREL16_S2 is b0_any=0xCC; PCREL16_S2 { goto PCREL16_S2; }
:jmp PCREL32_D4 is b0_any=0xDC; PCREL32_D4 { goto PCREL32_D4; }

:call PCREL16_D2, REGLIST_B3, IMM8_B4 is b0_any=0xCD; PCREL16_D2; REGLIST_B3; IMM8_B4 { call PCREL16_D2; }
:call PCREL32_D4, REGLIST_B5, IMM8_B6 is b0_any=0xDD; PCREL32_D4; REGLIST_B5; IMM8_B6 { call PCREL32_D4; }
:calls IND_AREG_D0 is b0_any=0xF0; b1_7=1 & b1_6=1 & b1_5=1 & b1_4=1 & b1_3=0 & b1_2=0 & IND_AREG_D0 { call [IND_AREG_D0]; }
:calls PCREL16_D2 is b0_any=0xFA; b1_any=0xFF; PCREL16_D2 { call PCREL16_D2; }
:calls PCREL32_D4 is b0_any=0xFC; b1_any=0xFF; PCREL32_D4 { call PCREL32_D4; }

:ret REGLIST_B1, IMM8_B2 is b0_any=0xDF; REGLIST_B1; IMM8_B2 {
    # Linux MN103 usage indicates ret [reglist],imm8 unwinds a frame and
    # returns via the address at (SP + imm8). Keep reglist effects conservative.
    local frame:4 = zext(IMM8_B2);
    local ra_ptr:4 = SP + frame;
    SP = SP + frame + 4;
    return [ra_ptr];
}
:retf REGLIST_B1, IMM8_B2 is b0_any=0xDE; REGLIST_B1; IMM8_B2 {
    local frame:4 = zext(IMM8_B2);
    local ra_ptr:4 = SP + frame;
    SP = SP + frame + 4;
    return [ra_ptr];
}
:rets is b0_any=0xF0; b1_any=0xFC { return [SP]; }
:rti is b0_any=0xF0; b1_any=0xFD { return [SP]; }
:rtm is b0_any=0xF0; b1_any=0xFF { return [SP]; }

:trap is b0_any=0xF0; b1_any=0xFE {
    local code:4 = 0xfe;
    mn103_trap(code);
}
:syscall IMM4_B1 is b0_any=0xF0; b1_7=1 & b1_6=1 & b1_5=1 & b1_4=0 & IMM4_B1 {
    local code:4 = zext(IMM4_B1);
    mn103_syscall(code);
}
:syscall is b0_any=0xF0; b1_any=0xC0 {
    local code:4 = 0;
    mn103_syscall(code);
}
:break is b0_any=0xFF {
    local code:4 = 0xff;
    mn103_break(code);
}

macro update_zn32(val) {
    $(ZF) = (val == 0);
    $(NF) = (val s< 0);
}

macro update_add32(dst, src) {
    $(VF) = scarry(dst, src);
    $(CF) = carry(dst, src);
    dst = dst + src;
    update_zn32(dst);
}

macro update_sub32(dst, src) {
    $(VF) = sborrow(dst, src);
    $(CF) = (src > dst);
    dst = dst - src;
    update_zn32(dst);
}

macro update_cmp32(a, b) {
    $(VF) = sborrow(a, b);
    $(CF) = (b > a);
    local r:4 = a - b;
    update_zn32(r);
}

macro update_and32(dst, src) {
    dst = dst & src;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_or32(dst, src) {
    dst = dst | src;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_xor32(dst, src) {
    dst = dst ^ src;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_not32(dst) {
    dst = ~dst;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_lsr32(dst, count) {
    local sh:4 = count & 0x1f;
    local old:4 = dst;
    if (sh != 0) goto <DO_SHIFT>;
    $(CF) = 0;
    goto <DONE_SHIFT>;
<DO_SHIFT>
    local ctmp:4 = old >> (sh - 1);
    local cbit:4 = ctmp & 1;
    $(CF) = (cbit != 0);
    dst = old >> sh;
<DONE_SHIFT>
    $(VF) = 0;
    update_zn32(dst);
}

macro update_asl32(dst, count) {
    local sh:4 = count & 0x1f;
    local old:4 = dst;
    if (sh != 0) goto <DO_ASL_SHIFT>;
    $(CF) = 0;
    goto <DONE_ASL_SHIFT>;
<DO_ASL_SHIFT>
    local ctmp:4 = old >> (32 - sh);
    local cbit:4 = ctmp & 1;
    $(CF) = (cbit != 0);
    dst = old << sh;
<DONE_ASL_SHIFT>
    $(VF) = 0;
    update_zn32(dst);
}

macro update_asr32(dst, count) {
    local sh:4 = count & 0x1f;
    local old:4 = dst;
    if (sh != 0) goto <DO_ASR_SHIFT>;
    $(CF) = 0;
    goto <DONE_ASR_SHIFT>;
<DO_ASR_SHIFT>
    local ctmp:4 = old >> (sh - 1);
    local cbit:4 = ctmp & 1;
    $(CF) = (cbit != 0);
    dst = old s>> sh;
<DONE_ASR_SHIFT>
    $(VF) = 0;
    update_zn32(dst);
}

macro update_bset_mem8(bitidx, m) {
    local bit:4 = bitidx & 7;
    local mask:1 = 1 << bit;
    m = m | mask;
}

macro update_bclr_mem8(bitidx, m) {
    local bit:4 = bitidx & 7;
    local mask:1 = 1 << bit;
    m = m & ~mask;
}

macro update_addc32(dst, src) {
    local c:4 = zext($(CF));
    local t:4 = dst + src;
    local cf1:1 = carry(dst, src);
    local vf1:1 = scarry(dst, src);
    local cf2:1 = carry(t, c);
    local vf2:1 = scarry(t, c);
    dst = t + c;
    $(CF) = cf1 | cf2;
    $(VF) = vf1 | vf2;
    update_zn32(dst);
}

macro update_subc32(dst, src) {
    local c:4 = zext($(CF));
    local t:4 = dst - src;
    local cf1:1 = (src > dst);
    local vf1:1 = sborrow(dst, src);
    local cf2:1 = (c > t);
    local vf2:1 = sborrow(t, c);
    dst = t - c;
    $(CF) = cf1 | cf2;
    $(VF) = vf1 | vf2;
    update_zn32(dst);
}

macro update_btst_reg32(bitidx, src) {
    local bit:4 = bitidx & 0x1f;
    local t:4 = src >> bit;
    local low:4 = t & 1;
    $(ZF) = (low == 0);
}

macro update_mulu32(dst, src) {
    local lhs:8 = zext(dst);
    local rhs:8 = zext(src);
    local prod:8 = lhs * rhs;
    dst = prod:4;
    local hi:8 = prod >> 32;
    MDR = hi:2;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro swaph_word32(dst, src) {
    local v:4 = src;
    local upper:4 = v & 0xffff0000;
    local lo0:4 = v & 0x000000ff;
    local lo1:4 = v & 0x0000ff00;
    dst = upper | (lo0 << 8) | (lo1 >> 8);
}

# arithmetic/logic baseline (staged subset)
:add DREG_S0_HI, DREG_S0_LO is b0_7=1 & b0_6=1 & b0_5=1 & b0_4=0 & DREG_S0_HI & DREG_S0_LO { update_add32(DREG_S0_LO, DREG_S0_HI); }
:add DREG_D0_HI, AREG_D0_LO is b0_any=0xF1; b1_7=0 & b1_6=1 & b1_5=1 & b1_4=0 & DREG_D0_HI & AREG_D0_LO { update_add32(AREG_D0_LO, DREG_D0_HI); }
:add AREG_D0_HI, DREG_D0_LO is b0_any=0xF1; b1_7=0 & b1_6=1 & b1_5=0 & b1_4=1 & AREG_D0_HI & DREG_D0_LO { update_add32(DREG_D0_LO, AREG_D0_HI); }
:add AREG_D0_HI, AREG_D0_LO is b0_any=0xF1; b1_7=0 & b1_6=1 & b1_5=1 & b1_4=1 & AREG_D0_HI & AREG_D0_LO { update_add32(AREG_D0_LO, AREG_D0_HI); }
:add SIMM8_B1, DREG_S1_LO is b0_7=0 & b0_6=0 & b0_5=1 & b0_4=0 & b0_3=1 & b0_2=0 & DREG_S1_LO; SIMM8_B1 { local s:4 = sext(SIMM8_B1); update_add32(DREG_S1_LO, s); }
:add SIMM8_B1, AREG_S1_LO is b0_7=0 & b0_6=0 & b0_5=1 & b0_4=0 & b0_3=0 & b0_2=0 & AREG_S1_LO; SIMM8_B1 { local s:4 = sext(SIMM8_B1); update_add32(AREG_S1_LO, s); }
:add SIMM16_B23, DREG_D0_LO is b0_any=0xFA; b1_7=1 & b1_6=1 & b1_5=0 & b1_4=0 & b1_3=0 & b1_2=0 & DREG_D0_LO; SIMM16_B23 { local s:4 = sext(SIMM16_B23); update_add32(DREG_D0_LO, s); }
:add SIMM16_B23, AREG_D0_LO is b0_any=0xFA; b1_7=1 & b1_6=1 & b1_5=0 & b1_4=1 & b1_3=0 & b1_2=0 & AREG_D0_LO; SIMM16_B23 { local s:4 = sext(SIMM16_B23); update_add32(AREG_D0_LO, s); }
:add SIMM8_B2, "SP" is b0_any=0xF8; b1_any=0xFE; SIMM8_B2 { local s:4 = sext(SIMM8_B2); update_add32(SP, s); }
:add SIMM16_B23, "SP" is b0_any=0xFA; b1_any=0xFE; SIMM16_B23 { local s:4 = sext(SIMM16_B23); update_add32(SP, s); }
:add RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0x78; RREG_B2_HI & RREG_B2_LO { update_add32(RREG_B2_LO, RREG_B2_HI); }
:add IMM32_B2345, DREG_D0_LO is b0_any=0xFC; b1_7=1 & b1_6=1 & b1_5=0 & b1_4=0 & b1_3=0 & b1_2=0 & DREG_D0_LO; IMM32_B2345 { update_add32(DREG_D0_LO, IMM32_B2345); }
:add IMM32_B2345, AREG_D0_LO is b0_any=0xFC; b1_7=1 & b1_6=1 & b1_5=0 & b1_4=1 & b1_3=0 & b1_2=0 & AREG_D0_LO; IMM32_B2345 { update_add32(AREG_D0_LO, IMM32_B2345); }
:add IMM32_B2345, "SP" is b0_any=0xFC; b1_any=0xFE; IMM32_B2345 { update_add32(SP, IMM32_B2345); }

# AM33 D10 pair-op forms used by Linux hand-optimized routines.
:add_add RREG_B3_HI, RREG_B3_LO, RREG_B2_HI, RREG_B2_LO is b0_any=0xF7; b1_any=0x00; RREG_B2_HI & RREG_B2_LO; RREG_B3_HI & RREG_B3_LO {
    update_add32(RREG_B3_LO, RREG_B3_HI);
    update_add32(RREG_B2_LO, RREG_B2_HI);
}
:add_add RREG_B3_HI, RREG_B3_LO, SIMM4_B2_HI, RREG_B2_LO is b0_any=0xF7; b1_any=0x10; SIMM4_B2_HI & RREG_B2_LO; RREG_B3_HI & RREG_B3_LO {
    local s2:4 = sext(SIMM4_B2_HI);
