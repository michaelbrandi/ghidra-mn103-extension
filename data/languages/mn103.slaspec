    b1_any = (0,7)
    b1_imm = (0,7) hex
    b1_simm = (0,7) signed hex
    b1_areg0 = (0,1)
    b1_dlo = (0,1)
    b1_dhi = (2,3)
    b1_d2 = (4,5)
    b1_alo = (0,1)
    b1_ahi = (2,3)
    b1_a2 = (4,5)
    b1_rlo = (0,3)
    b1_rhi = (4,7)
    b1_rmid = (2,5)
    b1_xrlo = (0,3)
    b1_xrhi = (4,7)
    b1_xrmid = (2,5)
    b1_imm4lo = (0,3) hex
    b1_imm4hi = (4,7) hex
    b1_simm4lo = (0,3) signed hex
    b1_simm4hi = (4,7) signed hex
    b1_fsl0 = (0,3)
