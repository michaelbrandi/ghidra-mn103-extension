:mul RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0xA9; RREG_B2_HI & RREG_B2_LO {
    RREG_B2_LO = RREG_B2_LO * RREG_B2_HI;
    update_zn32(RREG_B2_LO);
}
:div RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0xC9; RREG_B2_HI & RREG_B2_LO {
    if (RREG_B2_HI == 0) goto <DONE>;
    RREG_B2_LO = RREG_B2_LO / RREG_B2_HI;
    update_zn32(RREG_B2_LO);
<DONE>
}
:divu RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0xD9; RREG_B2_HI & RREG_B2_LO {
    if (RREG_B2_HI == 0) goto <DONE>;
    RREG_B2_LO = RREG_B2_LO / RREG_B2_HI;
    update_zn32(RREG_B2_LO);
<DONE>
}

:mac RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0x0B; RREG_B2_HI & RREG_B2_LO {
    local p:8 = sext(RREG_B2_LO) * sext(RREG_B2_HI);
    local lo:4 = p:4;
    local psh:8 = p >> 32;
    local hi:4 = psh:4;
    local nl:4 = MCRL + lo;
    local c:4 = 0;
    if (nl < MCRL) goto <MAC_C>;
    if (nl < lo) goto <MAC_C>;
    goto <MAC_C_DONE>;
<MAC_C>
    c = 1;
<MAC_C_DONE>
    MCRL = nl;
    MCRH = MCRH + hi + c;
}
:macu RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0x1B; RREG_B2_HI & RREG_B2_LO {
    local p:8 = zext(RREG_B2_LO) * zext(RREG_B2_HI);
    local lo:4 = p:4;
    local psh:8 = p >> 32;
    local hi:4 = psh:4;
    local nl:4 = MCRL + lo;
    local c:4 = 0;
    if (nl < MCRL) goto <MACU_C>;
    if (nl < lo) goto <MACU_C>;
    goto <MACU_C_DONE>;
<MACU_C>
    c = 1;
<MACU_C_DONE>
    MCRL = nl;
    MCRH = MCRH + hi + c;
}
:macb RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0x2B; RREG_B2_HI & RREG_B2_LO {
    local t:4 = sext(RREG_B2_LO:1) * sext(RREG_B2_HI:1);
    MCRL = MCRL + t;
}
:macbu RREG_B2_HI, RREG_B2_LO is b0_any=0xF9; b1_any=0x3B; RREG_B2_HI & RREG_B2_LO {
    local t:4 = zext(RREG_B2_LO:1) * zext(RREG_B2_HI:1);
