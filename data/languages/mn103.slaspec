attach variables [ b0_dlo b0_dhi b1_dlo b1_dhi ] [ D0 D1 D2 D3 ];
attach variables [ b0_alo b0_ahi b1_alo b1_ahi b1_areg0 ] [ A0 A1 A2 SP ];
attach variables [ b1_d2 ] [ D0 D1 D2 D3 ];
attach variables [ b1_a2 ] [ A0 A1 A2 SP ];
attach variables [ b1_rlo b1_rhi b1_rmid b2_rlo b2_rhi b3_rlo b3_rhi ] [ R0 R1 R2 R3 R4 R5 R6 R7 A0 A1 A2 SP D0 D1 D2 D3 ];
attach variables [ b1_xrlo b1_xrhi b1_xrmid b2_xrlo b2_xrhi b3_xrlo b3_xrhi ] [ SP XR1 XR2 XR3 XR4 XR5 XR6 XR7 XR8 XR9 XR10 XR11 XR12 XR13 XR14 XR15 ];
attach variables [ b2_fsl0 b2_fsh0 b3_fsl0 b3_fsh0 ] [ FS0 FS1 FS2 FS3 FS4 FS5 FS6 FS7 FS8 FS9 FS10 FS11 FS12 FS13 FS14 FS15 ];
attach variables [ b2_fsl1 b2_fsh1 b3_fsl1 b3_fsh1 ] [ FS16 FS17 FS18 FS19 FS20 FS21 FS22 FS23 FS24 FS25 FS26 FS27 FS28 FS29 FS30 FS31 ];
attach variables [ b2_fdl0 b2_fdh0 b3_fdl0 b3_fdh0 ] [ FD0 FD1 FD2 FD3 FD4 FD5 FD6 FD7 FD8 FD9 FD10 FD11 FD12 FD13 FD14 FD15 ];
attach variables [ b2_fdl1 b2_fdh1 b3_fdl1 b3_fdh1 ] [ FD16 FD17 FD18 FD19 FD20 FD21 FD22 FD23 FD24 FD25 FD26 FD27 FD28 FD29 FD30 FD31 ];

@define ZF "PSW[0,1]"
@define NF "PSW[1,1]"
@define CF "PSW[2,1]"
@define VF "PSW[3,1]"

# Phase 2: key control-flow operands + p-code

IND_AREG_D0: "("^b1_areg0^")" is b1_areg0 { export b1_areg0; }
PCREL8_S1: addr is b1_simm [ addr = inst_start + b1_simm; ] { export *[ram]:4 addr; }
PCREL8_D1: addr is b2_simm [ addr = inst_start + b2_simm; ] { export *[ram]:4 addr; }
PCREL16_S2: addr is b1_any; b2_simm [ addr = inst_start + (b1_any | (b2_simm << 8)); ] { export *[ram]:4 addr; }
PCREL16_D2: addr is b2_any; b3_simm [ addr = inst_start + (b2_any | (b3_simm << 8)); ] { export *[ram]:4 addr; }
PCREL32_S4: addr is b1_any; b2_any; b3_any; b4_simm [ addr = inst_start + (b1_any | (b2_any << 8) | (b3_any << 16) | (b4_simm << 24)); ] { export *[ram]:4 addr; }
CALL16_S4: addr is b1_any; b2_simm; b3_any; b4_any [ addr = inst_start + (b1_any | (b2_simm << 8)); ] { export *[ram]:4 addr; }
PCREL32_D4: addr is b2_any; b3_any; b4_any; b5_simm [ addr = inst_start + (b2_any | (b3_any << 8) | (b4_any << 16) | (b5_simm << 24)); ] { export *[ram]:4 addr; }
CALL32_S6: addr is b1_any; b2_any; b3_any; b4_simm; b5_any; b6_any [ addr = inst_start + (b1_any | (b2_any << 8) | (b3_any << 16) | (b4_simm << 24)); ] { export *[ram]:4 addr; }

:beq PCREL8_S1 is b0_any=0xC8; PCREL8_S1 { if ($(ZF) == 1) goto PCREL8_S1; }
:bne PCREL8_S1 is b0_any=0xC9; PCREL8_S1 { if ($(ZF) == 0) goto PCREL8_S1; }
:bgt PCREL8_S1 is b0_any=0xC1; PCREL8_S1 { if (($(ZF) == 0) && ((($(NF) == 1) ^ ($(VF) == 1)) == 0)) goto PCREL8_S1; }
:bge PCREL8_S1 is b0_any=0xC2; PCREL8_S1 { if ((($(NF) == 1) ^ ($(VF) == 1)) == 0) goto PCREL8_S1; }
:ble PCREL8_S1 is b0_any=0xC3; PCREL8_S1 { if (($(ZF) == 1) || (($(NF) == 1) ^ ($(VF) == 1))) goto PCREL8_S1; }
:blt PCREL8_S1 is b0_any=0xC0; PCREL8_S1 { if (($(VF) == 1) ^ ($(NF) == 1)) goto PCREL8_S1; }
:bhi PCREL8_S1 is b0_any=0xC5; PCREL8_S1 { if (($(CF) == 0) && ($(ZF) == 0)) goto PCREL8_S1; }
:bcc PCREL8_S1 is b0_any=0xC6; PCREL8_S1 { if ($(CF) == 0) goto PCREL8_S1; }
:bls PCREL8_S1 is b0_any=0xC7; PCREL8_S1 { if (($(CF) == 1) || ($(ZF) == 1)) goto PCREL8_S1; }
:bcs PCREL8_S1 is b0_any=0xC4; PCREL8_S1 { if ($(CF) == 1) goto PCREL8_S1; }
:bvc PCREL8_D1 is b0_any=0xF8; b1_any=0xE8; PCREL8_D1 { if ($(VF) == 0) goto PCREL8_D1; }
:bvs PCREL8_D1 is b0_any=0xF8; b1_any=0xE9; PCREL8_D1 { if ($(VF) == 1) goto PCREL8_D1; }
:bnc PCREL8_D1 is b0_any=0xF8; b1_any=0xEA; PCREL8_D1 { if ($(NF) == 0) goto PCREL8_D1; }
:bns PCREL8_D1 is b0_any=0xF8; b1_any=0xEB; PCREL8_D1 { if ($(NF) == 1) goto PCREL8_D1; }
:bra PCREL8_S1 is b0_any=0xCA; PCREL8_S1 { goto PCREL8_S1; }

:jmp IND_AREG_D0 is b0_any=0xF0; b1_7=1 & b1_6=1 & b1_5=1 & b1_4=1 & b1_3=0 & b1_2=1 & IND_AREG_D0 { goto [IND_AREG_D0]; }
:jmp PCREL16_S2 is b0_any=0xCC; PCREL16_S2 { goto PCREL16_S2; }
:jmp PCREL32_S4 is b0_any=0xDC; PCREL32_S4 { goto PCREL32_S4; }

:call CALL16_S4 is b0_any=0xCD; CALL16_S4 { call CALL16_S4; }
:call CALL32_S6 is b0_any=0xDD; CALL32_S6 { call CALL32_S6; }
:calls IND_AREG_D0 is b0_any=0xF0; b1_7=1 & b1_6=1 & b1_5=1 & b1_4=1 & b1_3=0 & b1_2=0 & IND_AREG_D0 { call [IND_AREG_D0]; }
:calls PCREL16_D2 is b0_any=0xFA; b1_any=0xFF; PCREL16_D2 { call PCREL16_D2; }
:calls PCREL32_D4 is b0_any=0xFC; b1_any=0xFF; PCREL32_D4 { call PCREL32_D4; }

:ret is b0_any=0xDF; b1_any; b2_any { return [SP]; }
:retf is b0_any=0xDE; b1_any; b2_any { return [SP]; }
:rets is b0_any=0xF0; b1_any=0xFC { return [SP]; }
:rti is b0_any=0xF0; b1_any=0xFD { return [SP]; }
:rtm is b0_any=0xF0; b1_any=0xFF { return [SP]; }

# Phase 3: core mov/add/sub/cmp operand rendering + baseline semantics

macro update_zn32(val) {
    $(ZF) = (val == 0);
    $(NF) = (val s< 0);
}

macro update_bitop_flags32(val) {
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(val);
}

macro update_add32(dst, src) {
    $(VF) = scarry(dst, src);
    $(CF) = carry(dst, src);
    dst = dst + src;
    update_zn32(dst);
}

macro update_sub32(dst, src) {
    $(VF) = sborrow(dst, src);
    $(CF) = (src > dst);
    dst = dst - src;
    update_zn32(dst);
}

macro update_cmp32(a, b) {
    $(VF) = sborrow(a, b);
    $(CF) = (b > a);
    local r:4 = a - b;
    update_zn32(r);
}

macro update_and32(dst, src) {
    dst = dst & src;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_or32(dst, src) {
    dst = dst | src;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_xor32(dst, src) {
    dst = dst ^ src;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_not32(dst) {
    dst = ~dst;
    $(CF) = 0;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_asl32(dst, count) {
    local sh:4 = count & 0x1f;
    local old:4 = dst;
    local nz:1 = sh != 0;
    local cshift:4 = (32 - sh) & 0x1f;
    local c:1 = (old >> cshift) & 1;
    dst = old << sh;
    $(CF) = c & nz;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_lsr32(dst, count) {
    local sh:4 = count & 0x1f;
    local old:4 = dst;
    local nz:1 = sh != 0;
    local cshift:4 = (sh - 1) & 0x1f;
    local c:1 = (old >> cshift) & 1;
    dst = old >> sh;
    $(CF) = c & nz;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_asr32(dst, count) {
    local sh:4 = count & 0x1f;
    local old:4 = dst;
    local nz:1 = sh != 0;
    local cshift:4 = (sh - 1) & 0x1f;
    local c:1 = (old >> cshift) & 1;
    dst = old s>> sh;
    $(CF) = c & nz;
    $(VF) = 0;
    update_zn32(dst);
}

macro update_btst_reg32(bitidx, src) {
    local bit:4 = bitidx & 0x1f;
    local mask:4 = 1 << bit;
    local result:4 = src & mask;
    update_bitop_flags32(result);
}

macro update_btst_mem8(bitidx, m) {
    local bit:4 = bitidx & 7;
    local mask:1 = 1 << bit;
    local result:4 = zext(m) & zext(mask);
    update_bitop_flags32(result);
}

macro update_bset_mem8(bitidx, m) {
    local bit:4 = bitidx & 7;
    local mask:1 = 1 << bit;
    local result:4 = zext(m) & zext(mask);
    update_bitop_flags32(result);
    m = m | mask;
}

macro update_bclr_mem8(bitidx, m) {
    local bit:4 = bitidx & 7;
    local mask:1 = 1 << bit;
    local result:4 = zext(m) & zext(~mask);
    update_bitop_flags32(result);
    m = m & ~mask;
}

macro update_addc32(dst, src) {
    local c:4 = zext($(CF));
    local t:4 = dst + src;
    local cf1:1 = carry(dst, src);
    local vf1:1 = scarry(dst, src);
    local cf2:1 = carry(t, c);
    local vf2:1 = scarry(t, c);
    dst = t + c;
    $(CF) = cf1 | cf2;
    $(VF) = vf1 | vf2;
    update_zn32(dst);
}

macro update_subc32(dst, src) {
    local c:4 = zext($(CF));
    local t:4 = dst - src;
    local cf1:1 = (src > dst);
    local vf1:1 = sborrow(dst, src);
    local cf2:1 = (c > t);
    local vf2:1 = sborrow(t, c);
    dst = t - c;
    $(CF) = cf1 | cf2;
    $(VF) = vf1 | vf2;
    update_zn32(dst);
}

SIMM8_B1: b1_simm is b1_simm { local v:1 = b1_simm; export v; }
