define endian=little;
define alignment=1;

define space ram      type=ram_space      size=4 default;
define space register type=register_space size=4;

define register offset=0  size=4 [ PC A0 A1 A2 SP D0 D1 D2 D3 ];
define register offset=40 size=2 [ MDR PSW ];
define register offset=48 size=4 [ R0 R1 R2 R3 R4 R5 R6 R7 ];
define register offset=80 size=4 [ USP SSP MSP FPCR ];
define register offset=96 size=2 [ EPSW ];
define register offset=100 size=4 [ XR1 XR2 XR3 XR4 XR5 XR6 XR7 XR8 XR9 XR10 XR11 XR12 XR13 XR14 XR15 ];
define register offset=160 size=4 [ FS0 FS1 FS2 FS3 FS4 FS5 FS6 FS7 FS8 FS9 FS10 FS11 FS12 FS13 FS14 FS15 FS16 FS17 FS18 FS19 FS20 FS21 FS22 FS23 FS24 FS25 FS26 FS27 FS28 FS29 FS30 FS31 ];
define register offset=288 size=4 [ FD0 FD1 FD2 FD3 FD4 FD5 FD6 FD7 FD8 FD9 FD10 FD11 FD12 FD13 FD14 FD15 FD16 FD17 FD18 FD19 FD20 FD21 FD22 FD23 FD24 FD25 FD26 FD27 FD28 FD29 FD30 FD31 ];

define token b0 (8)
    b0_any = (0,7)
    b0_imm = (0,7) hex
    b0_simm = (0,7) signed hex
    b0_areg0 = (0,1)
    b0_dlo = (0,1)
    b0_dhi = (2,3)
    b0_d2 = (4,5)
    b0_alo = (0,1)
    b0_ahi = (2,3)
    b0_a2 = (4,5)
    b0_rlo = (0,3)
    b0_rhi = (4,7)
    b0_rmid = (2,5)
    b0_xrlo = (0,3)
    b0_xrhi = (4,7)
    b0_xrmid = (2,5)
    b0_imm4lo = (0,3) hex
    b0_imm4hi = (4,7) hex
    b0_simm4lo = (0,3) signed hex
    b0_simm4hi = (4,7) signed hex
    b0_fsl0 = (0,3)
    b0_fsh0 = (4,7)
    b0_fsl1 = (0,3)
    b0_fsh1 = (4,7)
    b0_fdl0 = (0,3)
    b0_fdh0 = (4,7)
    b0_fdl1 = (0,3)
    b0_fdh1 = (4,7)
    b0_0 = (0,0)
    b0_1 = (1,1)
    b0_2 = (2,2)
    b0_3 = (3,3)
    b0_4 = (4,4)
    b0_5 = (5,5)
    b0_6 = (6,6)
    b0_7 = (7,7)
;

