IMM24_B345:  b3_any; b4_any; b5_any is b3_any; b4_any; b5_any {
    local b3v:4 = b3_any;
    local b4v:4 = b4_any;
    local b5v:4 = b5_any;
    local v:4 = b3v | (b4v << 8) | (b5v << 16);
    export v;
}
SIMM24_B345: b3_any; b4_any; b5_any is b3_any; b4_any; b5_any {
    local b3v:4 = b3_any;
    local b4v:4 = b4_any;
    local b5v:4 = b5_any;
    local v:4 = b3v | (b4v << 8) | (b5v << 16);
    if ((v & 0x00800000) != 0) goto <SIGN_EXTEND>;
    goto <DONE>;
<SIGN_EXTEND>
    v = v | 0xff000000;
<DONE>
    export v;
}
