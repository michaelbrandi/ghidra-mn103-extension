REGLIST_B2: "[d3,a2]" is b2_any=0x60 { }
REGLIST_B2: "[d2,d3,a2]" is b2_any=0xE0 { }
REGLIST_B2: "[d2,d3,a2,a3]" is b2_any=0xF0 { }
REGLIST_B2: "[d2,d3,a2,a3,exreg1]" is b2_any=0xF2 { }
REGLIST_B2: "["^b2_imm^"]" is b2_imm { }

REGLIST_B3: "[]" is b3_any=0x00 { }
REGLIST_B3: "[d2]" is b3_any=0x80 { }
REGLIST_B3: "[d3]" is b3_any=0x40 { }
REGLIST_B3: "[a2]" is b3_any=0x20 { }
REGLIST_B3: "[a3]" is b3_any=0x10 { }
REGLIST_B3: "[d2,d3]" is b3_any=0xC0 { }
REGLIST_B3: "[d3,a2]" is b3_any=0x60 { }
REGLIST_B3: "[d2,d3,a2]" is b3_any=0xE0 { }
REGLIST_B3: "[d2,d3,a2,a3]" is b3_any=0xF0 { }
REGLIST_B3: "[d2,d3,a2,a3,exreg1]" is b3_any=0xF2 { }
REGLIST_B3: "["^b3_imm^"]" is b3_imm { }

REGLIST_B5: "[]" is b5_any=0x00 { }
REGLIST_B5: "[d2]" is b5_any=0x80 { }
REGLIST_B5: "[d3]" is b5_any=0x40 { }
REGLIST_B5: "[a2]" is b5_any=0x20 { }
REGLIST_B5: "[a3]" is b5_any=0x10 { }
REGLIST_B5: "[d2,d3]" is b5_any=0xC0 { }
REGLIST_B5: "[d3,a2]" is b5_any=0x60 { }
REGLIST_B5: "[d2,d3,a2]" is b5_any=0xE0 { }
REGLIST_B5: "[d2,d3,a2,a3]" is b5_any=0xF0 { }
REGLIST_B5: "[d2,d3,a2,a3,exreg1]" is b5_any=0xF2 { }
REGLIST_B5: "["^b5_imm^"]" is b5_imm { }

# Phase 3 (staged): compile-safe mov/fmov subset

:nop is b0_any=0xCB { }
:beq PCREL8_S1 is b0_any=0xC8; PCREL8_S1 { if ($(ZF) == 1) goto PCREL8_S1; }
:bne PCREL8_S1 is b0_any=0xC9; PCREL8_S1 { if ($(ZF) == 0) goto PCREL8_S1; }
:bgt PCREL8_S1 is b0_any=0xC1; PCREL8_S1 { if (($(ZF) == 0) && ((($(NF) == 1) ^ ($(VF) == 1)) == 0)) goto PCREL8_S1; }
:bge PCREL8_S1 is b0_any=0xC2; PCREL8_S1 { if ((($(NF) == 1) ^ ($(VF) == 1)) == 0) goto PCREL8_S1; }
:ble PCREL8_S1 is b0_any=0xC3; PCREL8_S1 { if (($(ZF) == 1) || (($(NF) == 1) ^ ($(VF) == 1))) goto PCREL8_S1; }
:blt PCREL8_S1 is b0_any=0xC0; PCREL8_S1 { if (($(VF) == 1) ^ ($(NF) == 1)) goto PCREL8_S1; }
:bhi PCREL8_S1 is b0_any=0xC5; PCREL8_S1 { if (($(CF) == 0) && ($(ZF) == 0)) goto PCREL8_S1; }
:bcc PCREL8_S1 is b0_any=0xC6; PCREL8_S1 { if ($(CF) == 0) goto PCREL8_S1; }
:bls PCREL8_S1 is b0_any=0xC7; PCREL8_S1 { if (($(CF) == 1) || ($(ZF) == 1)) goto PCREL8_S1; }
:bcs PCREL8_S1 is b0_any=0xC4; PCREL8_S1 { if ($(CF) == 1) goto PCREL8_S1; }
:bvc PCREL8_D1 is b0_any=0xF8; b1_any=0xE8; PCREL8_D1 { if ($(VF) == 0) goto PCREL8_D1; }
:bvs PCREL8_D1 is b0_any=0xF8; b1_any=0xE9; PCREL8_D1 { if ($(VF) == 1) goto PCREL8_D1; }
:bnc PCREL8_D1 is b0_any=0xF8; b1_any=0xEA; PCREL8_D1 { if ($(NF) == 0) goto PCREL8_D1; }
:bns PCREL8_D1 is b0_any=0xF8; b1_any=0xEB; PCREL8_D1 { if ($(NF) == 1) goto PCREL8_D1; }
:bra PCREL8_S1 is b0_any=0xCA; PCREL8_S1 { goto PCREL8_S1; }
:setlb is b0_any=0xDB {
    # AM33 manual: SETLB registers a 4-byte loop body beginning at PC+1.
    local loop_start:4 = inst_start + 1;
    LIR = loop_start;
    LAR = loop_start + 4;
}
# Linux cache/poll loops use these short loop-condition aliases after setlb.
:llt is b0_any=0xD0; LOOP4BACK {
    if (LAR == 0) goto <DONE_LLT>;
    if (($(VF) == 1) ^ ($(NF) == 1)) goto LOOP4BACK;
<DONE_LLT>
}
:lgt is b0_any=0xD1; LOOP4BACK {
    if (LAR == 0) goto <DONE_LGT>;
    if (($(ZF) == 0) && ((($(NF) == 1) ^ ($(VF) == 1)) == 0)) goto LOOP4BACK;
<DONE_LGT>
}
:lge is b0_any=0xD2; LOOP4BACK {
    if (LAR == 0) goto <DONE_LGE>;
    if ((($(NF) == 1) ^ ($(VF) == 1)) == 0) goto LOOP4BACK;
<DONE_LGE>
}
:lle is b0_any=0xD3; LOOP4BACK {
    if (LAR == 0) goto <DONE_LLE>;
    if (($(ZF) == 1) || (($(NF) == 1) ^ ($(VF) == 1))) goto LOOP4BACK;
<DONE_LLE>
}
:lcs is b0_any=0xD4; LOOP4BACK {
    if (LAR == 0) goto <DONE_LCS>;
    if ($(CF) == 1) goto LOOP4BACK;
<DONE_LCS>
}
:lhi is b0_any=0xD5; LOOP4BACK {
    if (LAR == 0) goto <DONE_LHI>;
    if (($(CF) == 0) && ($(ZF) == 0)) goto LOOP4BACK;
<DONE_LHI>
}
:lcc is b0_any=0xD6; LOOP4BACK {
    if (LAR == 0) goto <DONE_LCC>;
    if ($(CF) == 0) goto LOOP4BACK;
<DONE_LCC>
}
:lls is b0_any=0xD7; LOOP4BACK {
    if (LAR == 0) goto <DONE_LLS>;
    if (($(CF) == 1) || ($(ZF) == 1)) goto LOOP4BACK;
<DONE_LLS>
}
:leq is b0_any=0xD8; LOOP4BACK {
    if (LAR == 0) goto <DONE_LEQ>;
    if ($(ZF) == 1) goto LOOP4BACK;
<DONE_LEQ>
}
:lne is b0_any=0xD9; LOOP4BACK {
    if (LAR == 0) goto <DONE_LNE>;
    if ($(ZF) == 0) goto LOOP4BACK;
<DONE_LNE>
}
:lra is b0_any=0xDA; LOOP4BACK {
    if (LAR == 0) goto <DONE_LRA>;
    goto LOOP4BACK;
<DONE_LRA>
}

# MOVM stack semantics for the modeled register subset. Unknown architectural
# regs are still accounted for in stack layout/size.
:movm "(SP)", REGLIST_B1 is b0_any=0xCE; b1_any & REGLIST_B1 {
    local p:4 = SP;
    local mask:1 = b1_any;

    if ((mask & 0x08) == 0) goto <SP_POP_NO_DUMMY>;
    p = p + 4;
<SP_POP_NO_DUMMY>

    if ((mask & 0x08) == 0) goto <SP_POP_NO_OTHER>;
    LAR = *[ram]:4 p; p = p + 4;
    LIR = *[ram]:4 p; p = p + 4;
    MDR = *[ram]:4 p; p = p + 4;
    A1 = *[ram]:4 p; p = p + 4;
    A0 = *[ram]:4 p; p = p + 4;
    D1 = *[ram]:4 p; p = p + 4;
    D0 = *[ram]:4 p; p = p + 4;
<SP_POP_NO_OTHER>

    if ((mask & 0x10) == 0) goto <SP_POP_NO_A3>;
    p = p + 4;
<SP_POP_NO_A3>
    if ((mask & 0x20) == 0) goto <SP_POP_NO_A2>;
    A2 = *[ram]:4 p; p = p + 4;
<SP_POP_NO_A2>
    if ((mask & 0x40) == 0) goto <SP_POP_NO_D3>;
    D3 = *[ram]:4 p; p = p + 4;
<SP_POP_NO_D3>
    if ((mask & 0x80) == 0) goto <SP_POP_NO_D2>;
    D2 = *[ram]:4 p; p = p + 4;
<SP_POP_NO_D2>

    if ((mask & 0x01) == 0) goto <SP_POP_NO_EXOTHER>;
    MCVF = *[ram]:4 p; p = p + 4;
    MCRL = *[ram]:4 p; p = p + 4;
    MCRH = *[ram]:4 p; p = p + 4;
    MDRQ = *[ram]:4 p; p = p + 4;
    R1 = *[ram]:4 p; p = p + 4;
    R0 = *[ram]:4 p; p = p + 4;
<SP_POP_NO_EXOTHER>

    if ((mask & 0x02) == 0) goto <SP_POP_NO_EXREG1>;
    R7 = *[ram]:4 p; p = p + 4;
    R6 = *[ram]:4 p; p = p + 4;
    R5 = *[ram]:4 p; p = p + 4;
    R4 = *[ram]:4 p; p = p + 4;
<SP_POP_NO_EXREG1>

    if ((mask & 0x04) == 0) goto <SP_POP_NO_EXREG0>;
    R3 = *[ram]:4 p; p = p + 4;
    R2 = *[ram]:4 p; p = p + 4;
<SP_POP_NO_EXREG0>

    SP = p;
}
:movm REGLIST_B1, "(SP)" is b0_any=0xCF; b1_any & REGLIST_B1 {
    local p:4 = SP;
    local mask:1 = b1_any;

    if ((mask & 0x04) == 0) goto <SP_PUSH_NO_EXREG0>;
    p = p - 4; *[ram]:4 p = R2;
    p = p - 4; *[ram]:4 p = R3;
<SP_PUSH_NO_EXREG0>

    if ((mask & 0x02) == 0) goto <SP_PUSH_NO_EXREG1>;
    p = p - 4; *[ram]:4 p = R4;
    p = p - 4; *[ram]:4 p = R5;
    p = p - 4; *[ram]:4 p = R6;
    p = p - 4; *[ram]:4 p = R7;
<SP_PUSH_NO_EXREG1>

    if ((mask & 0x01) == 0) goto <SP_PUSH_NO_EXOTHER>;
    p = p - 4; *[ram]:4 p = R0;
    p = p - 4; *[ram]:4 p = R1;
    p = p - 4; *[ram]:4 p = MDRQ;
    p = p - 4; *[ram]:4 p = MCRH;
    p = p - 4; *[ram]:4 p = MCRL;
    p = p - 4; *[ram]:4 p = MCVF;
<SP_PUSH_NO_EXOTHER>

    if ((mask & 0x80) == 0) goto <SP_PUSH_NO_D2>;
    p = p - 4; *[ram]:4 p = D2;
<SP_PUSH_NO_D2>
    if ((mask & 0x40) == 0) goto <SP_PUSH_NO_D3>;
    p = p - 4; *[ram]:4 p = D3;
<SP_PUSH_NO_D3>
    if ((mask & 0x20) == 0) goto <SP_PUSH_NO_A2>;
    p = p - 4; *[ram]:4 p = A2;
<SP_PUSH_NO_A2>
    if ((mask & 0x10) == 0) goto <SP_PUSH_NO_A3>;
    p = p - 4;
<SP_PUSH_NO_A3>

    if ((mask & 0x08) == 0) goto <SP_PUSH_NO_OTHER>;
    p = p - 4; *[ram]:4 p = D0;
    p = p - 4; *[ram]:4 p = D1;
    p = p - 4; *[ram]:4 p = A0;
    p = p - 4; *[ram]:4 p = A1;
    p = p - 4; *[ram]:4 p = MDR;
    p = p - 4; *[ram]:4 p = LIR;
    p = p - 4; *[ram]:4 p = LAR;
    p = p - 4;
<SP_PUSH_NO_OTHER>

    SP = p;
}
:movm "(USP)", REGLIST_B2 is b0_any=0xF8; b1_any=0xCE; b2_any & REGLIST_B2 {
    local p:4 = USP;
