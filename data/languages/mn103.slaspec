:sub_sub SIMM4_B3_HI, RREG_B3_LO, SIMM4_B2_HI, RREG_B2_LO is b0_any=0xF7; b1_any=0x36; SIMM4_B2_HI & RREG_B2_LO; SIMM4_B3_HI & RREG_B3_LO {
