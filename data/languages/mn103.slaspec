<USP_PUSH_NO_D2>
    if ((mask & 0x40) == 0) goto <USP_PUSH_NO_D3>;
    p = p - 4; *[ram]:4 p = D3;
<USP_PUSH_NO_D3>
    if ((mask & 0x20) == 0) goto <USP_PUSH_NO_A2>;
    p = p - 4; *[ram]:4 p = A2;
<USP_PUSH_NO_A2>
    if ((mask & 0x10) == 0) goto <USP_PUSH_NO_A3>;
    p = p - 4;
<USP_PUSH_NO_A3>

    if ((mask & 0x08) == 0) goto <USP_PUSH_NO_OTHER>;
